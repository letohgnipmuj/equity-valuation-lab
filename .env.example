# ============================================
# FRONTEND ENVIRONMENT VARIABLES
# ============================================

# API Base URL (backend location)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# API Timeout Configuration (milliseconds)
# Time to wait for synchronous valuation response before switching to polling
NEXT_PUBLIC_API_TIMEOUT_MS=20000

# Polling Configuration (milliseconds)
# Interval between job status checks
NEXT_PUBLIC_POLL_INTERVAL_MS=3000

# Maximum polling attempts (duration = POLL_INTERVAL_MS * MAX_POLL_ATTEMPTS)
# Default 300 = ~15 minutes max wait time
NEXT_PUBLIC_MAX_POLL_ATTEMPTS=300

# CORS Origins for local development
NEXT_PUBLIC_CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============================================
# BACKEND ENVIRONMENT VARIABLES
# ============================================

# API Timeout Configuration (seconds)
# Backend synchronous execution timeout before switching to async job processing
API_SYNC_TIMEOUT_SECONDS=20

# Redis Configuration
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=2
REDIS_SOCKET_TIMEOUT_SECONDS=2
REDIS_HEALTH_CHECK_INTERVAL_SECONDS=30

# Cache TTL Configuration (seconds)
REDIS_DEFAULT_CACHE_TTL_SECONDS=86400
API_VALUATION_CACHE_TTL_SECONDS=14400
RAW_DATA_CACHE_TTL_SECONDS=604800
FMP_CACHE_TTL_SECONDS=86400
LOCAL_COMPANY_CACHE_TTL_SECONDS=60

# Financial Data API
FMP_API_KEY=your-api-key-here

# CORS
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
